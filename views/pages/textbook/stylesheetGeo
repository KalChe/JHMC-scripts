\usepackage{amsmath, amssymb}
\usepackage{geometry}
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{positioning, angles, quotes, calc, shapes.geometric}
\usepackage{float}
\usepackage[most]{tcolorbox}
\geometry{margin=1in}

\tcbuselibrary{theorems}

\tcbset{
  mytheostyle/.style={enhanced,
    colback=blue!5,
    colframe=blue!30!gray,
    fonttitle=\bfseries,
    coltitle=white,
    sharp corners},
  mydefstyle/.style={enhanced,
    colback=yellow!10,
    colframe=orange!80!black,
    fonttitle=\bfseries},
  myexamplestyle/.style={enhanced,
    colback=green!5,
    colframe=green!60!black,
    fonttitle=\bfseries}
}

\newtcbtheorem[number within=chapter]{theorem}{Theorem}{mytheostyle}{th}
\newtcbtheorem[number within=chapter]{definition}{Definition}{mydefstyle}{def}
\newtcbtheorem[number within=chapter]{example}{Example}{myexamplestyle}{ex}

% ---- Exercise box -----
\newtcolorbox{exercise}[1][]{title={Exercise}, colback=white,
  colframe=red!60!black,
  fonttitle=\bfseries,
  sharp corners}

% ---- Solution box ----
\newtcolorbox{solution}[1][]{title={Solution},
  colback=gray!5,          
  colframe=gray!60!black,  
  colbacktitle=gray!60!black, 
  coltitle=white,          
  fonttitle=\bfseries,
  sharp corners,
  boxrule=0.5pt,
  #1}

  